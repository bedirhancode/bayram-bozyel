---
import Base from '../layouts/Base.astro';
import EntryList from '../components/EntryList.astro';
import Portrait from '../components/Portrait.astro';
import { getCollection } from 'astro:content';

async function recent<T extends string>(name: T, limit: number) {
  const items = await getCollection(name as any, ({ data }: any) => !data.draft);
  return items
    .sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime())
    .slice(0, limit);
}

const [makaleler, roportajlar, etkinlikler, videolar] = await Promise.all([
  recent('makaleler', 4),
  recent('roportajlar', 3),
  recent('etkinlikler', 3),
  recent('videolar', 2),
]);

const map = (entries: any[], base: string, outletKey: string = 'outlet') =>
  entries.map((e) => ({
    href: `${base}/${e.id}`,
    title: e.data.title,
    date: e.data.date,
    outlet: e.data[outletKey] ?? e.data.sourceOutlet,
    location: e.data.location,
    summary: e.data.summary,
  }));
---
<Base
  description="Bayram Bozyel — yazar ve siyasetçi. Kürt siyaseti, demokrasi ve hak mücadelesi üzerine makaleler, röportajlar ve etkinlikler."
  wide
>
  <section class="hero" aria-labelledby="hero-title">
    <div>
      <p class="hero__eyebrow">Yazar · Siyasetçi</p>
      <h1 id="hero-title" class="hero__title">Bayram <em>Bozyel</em></h1>
      <p class="hero__lead">
        Kürt siyaseti, demokrasi ve hak mücadelesi üzerine yazılar.
        HAK-PAR'ın kurucu üyesi, eski Genel Başkanı; Kürdistan Sosyalist
        Partisi (PSK) Genel Başkanı.
      </p>
    </div>
    <Portrait size="sm" eager alt="Bayram Bozyel portresi" />
  </section>

  {makaleler.length > 0 && (
    <section class="section" aria-labelledby="makaleler-head">
      <div class="section__head">
        <h2 id="makaleler-head">Makaleler</h2>
        <a href="/makaleler" class="link-inline">Tümü <span class="arrow" aria-hidden="true">→</span></a>
      </div>
      <EntryList entries={map(makaleler, '/makaleler', 'sourceOutlet')} groupByYear={false} wide />
    </section>
  )}

  {roportajlar.length > 0 && (
    <section class="section" aria-labelledby="roportajlar-head">
      <div class="section__head">
        <h2 id="roportajlar-head">Röportajlar</h2>
        <a href="/roportajlar" class="link-inline">Tümü <span class="arrow" aria-hidden="true">→</span></a>
      </div>
      <EntryList entries={map(roportajlar, '/roportajlar')} groupByYear={false} wide />
    </section>
  )}

  {etkinlikler.length > 0 && (
    <section class="section" aria-labelledby="etkinlikler-head">
      <div class="section__head">
        <h2 id="etkinlikler-head">Etkinlikler</h2>
        <a href="/etkinlikler" class="link-inline">Tümü <span class="arrow" aria-hidden="true">→</span></a>
      </div>
      <EntryList entries={map(etkinlikler, '/etkinlikler')} groupByYear={false} wide />
    </section>
  )}

  {videolar.length > 0 && (
    <section class="section" aria-labelledby="videolar-head">
      <div class="section__head">
        <h2 id="videolar-head">Videolar</h2>
        <a href="/videolar" class="link-inline">Tümü <span class="arrow" aria-hidden="true">→</span></a>
      </div>
      <EntryList entries={map(videolar, '/videolar')} groupByYear={false} wide />
    </section>
  )}

  <p class="flourish" aria-hidden="true">·  ·  ·</p>
</Base>
