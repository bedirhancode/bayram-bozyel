---
import Base from '../../layouts/Base.astro';
import EntryList from '../../components/EntryList.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('etkinlikler', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((e) => ({
    href: `/etkinlikler/${e.id}`,
    title: e.data.title,
    date: e.data.date,
    location: e.data.location,
    summary: e.data.summary,
  }));
---
<Base title="Etkinlikler" description="Bayram Bozyel'in konuşmaları, panelleri ve kamuoyuna açık etkinlikleri." wide>
  <header class="post-header">
    <h1 class="post-header__title">Etkinlikler</h1>
    {items.length > 0 && (
      <p class="post-header__date">{items.length} kayıt</p>
    )}
  </header>

  {items.length === 0 ? (
    <div class="callout"><p>Henüz etkinlik yok.</p></div>
  ) : (
    <EntryList entries={items} wide />
  )}
</Base>
